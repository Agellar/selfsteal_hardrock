# Iron Wave Radio — selfsteal decoy for xray Reality
# ---------------------------------------------------------------------------
# Serves the static site over REAL TLS on 127.0.0.1:9443. xray Reality on :443
# uses this as its `target` (realitySettings.target = "127.0.0.1:9443") and
# forwards all non-Reality traffic (browsers, active probers) here — so they
# see a genuine, valid-certificate website. That is what makes the masking work.
#
# Requirements on the server:
#   - DNS for hardrock.legendaryfm.uk already points here (Reality needs it too).
#   - TCP port 80 OPEN to the internet — Let's Encrypt HTTP-01 challenge and
#     renewals. (TLS-ALPN on 443 is impossible: xray owns 443.)
#   - xray realitySettings.target = "127.0.0.1:9443"  (already set in your config)
#
# If you already run Caddy for other sites, copy ONLY the site block below into
# your existing Caddyfile instead of replacing the whole file.
# ---------------------------------------------------------------------------

{
	# ACME contact; certs are issued via HTTP-01 on port 80 because 443 is taken.
	email info@legendaryfm.uk
}

# Real TLS site that Reality points at. Bound to loopback so only xray reaches it.
https://hardrock.legendaryfm.uk:9443 {
	bind 127.0.0.1

	root * /var/www/hardrock
	file_server
	encode zstd gzip

	# Cache: fingerprinted assets (fonts/css/js) forever, HTML short.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	@html path *.html /
	header @html Cache-Control "public, max-age=600"

	# Modern-site headers — make the decoy look ordinary and well-configured.
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	log {
		output file /var/log/caddy/hardrock-access.log {
			roll_size 10MiB
			roll_keep 3
		}
		# Do not store client IPs / personal data (keeps the privacy policy honest).
		format filter {
			request>remote_ip delete
			request>remote_port delete
			request>headers>X-Forwarded-For delete
		}
	}
}
